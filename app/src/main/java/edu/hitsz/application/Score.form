<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="edu.hitsz.application.Score">
  <grid id="27dc6" binding="Panel" layout-manager="BorderLayout" hgap="20" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="ad3d1" binding="flowLayout" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="20" left="20" bottom="20" right="20"/>
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="e6e70" class="javax.swing.JLabel" binding="difficultyLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="24"/>
              <text value="难度："/>
            </properties>
          </component>
          <component id="733bd" class="javax.swing.JLabel" binding="difficulty">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <background color="-51575"/>
              <font size="24"/>
              <text value="Label"/>
            </properties>
          </component>
          <component id="1f6d6" class="javax.swing.JLabel" binding="rank">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="24"/>
              <text value="排行榜"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="ad8b3" binding="scrollPane">
        <constraints border-constraint="Center"/>
        <properties>
          <font/>
        </properties>
        <border type="none"/>
        <children>
          <component id="aff3e" class="javax.swing.JTable" binding="scoreTable">
            <constraints/>
            <properties>
              <font/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <component id="dfbf4" class="javax.swing.JButton" binding="deleteButton">
        <constraints border-constraint="South"/>
        <properties>
          <font size="20"/>
          <text value="删除选中记录"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
